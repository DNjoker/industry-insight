{
  "manifest_version": 3,
  "name": "DeepSeek → Obsidian",
  "version": "1.0",
  "description": "一键导出 DeepSeek 对话到 Obsidian 知识库",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://chat.deepseek.com/*",
    "http://127.0.0.1:19877/*"
  ],
  "content_scripts": [{
    "matches": ["https://chat.deepseek.com/*"],
    "js": ["content/content.js"],
    "css": ["content/floating-button.css"]
  }],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "导出到 Obsidian"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
